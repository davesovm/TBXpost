# ─────────────────────────────────────────────────────────────────────────────
# TBXpost — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# The channel the bot posts to. Use @handle for public channels.
TELEGRAM_CHANNEL=@yourchannel

# Your personal Telegram user ID (find it via @userinfobot)
# Only this user can run admin commands like /log, /generate, /post_now
TELEGRAM_ADMIN_ID=123456789

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_your-key-here


# ── OPTIONAL — AI ─────────────────────────────────────────────────────────────

# Groq model to use (default: llama-3.1-8b-instant — fast and free)
# Other options: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# Gemini API key — used as fallback if Groq fails (get at ai.google.dev)
GEMINI_API_KEY=

# Gemini model for fallback (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash


# ── OPTIONAL — SCHEDULER ──────────────────────────────────────────────────────

# Days to post, comma-separated. Options: mon,tue,wed,thu,fri,sat,sun
# Default: Monday and Thursday
POST_DAYS=mon,thu

# Hour to post (24h format, default: 9 = 9am)
POST_HOUR=9

# Minute to post (default: 0)
POST_MINUTE=0

# Timezone for the scheduler (default: UTC)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC


# ── OPTIONAL — CONTENT ────────────────────────────────────────────────────────

# Comma-separated RSS feed URLs for news fetching
# Default includes Hacker News frontpage and Dev.to
RSS_FEEDS=https://hnrss.org/frontpage,https://dev.to/feed

# Minimum AI quality score to post (0-10, default: 7)
# Articles scored below this by the AI are discarded
NEWS_MIN_SCORE=7


# ── OPTIONAL — STORAGE ────────────────────────────────────────────────────────

# Path to the SQLite database file (default: devpulse.db in project root)
DB_PATH=devpulse.db
