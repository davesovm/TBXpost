# ─────────────────────────────────────────────────────────────────────────────
# TBXpost — environment variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Channel the bot posts to — use @handle for public channels
TELEGRAM_CHANNEL=@yourchannel

# Your personal Telegram user ID — only this user can run commands
# Get it by messaging @userinfobot on Telegram
TELEGRAM_ADMIN_ID=123456789

# Groq API key — free at https://console.groq.com
GROQ_API_KEY=gsk_your-key-here


# ── OPTIONAL — AI ─────────────────────────────────────────────────────────────

# Groq model (default: llama-3.1-8b-instant — fast and free)
GROQ_MODEL=llama-3.1-8b-instant

# Gemini API key — fallback if Groq fails (get at ai.google.dev)
GEMINI_API_KEY=

# Gemini model for fallback
GEMINI_MODEL=gemini-1.5-flash


# ── OPTIONAL — CONTENT ────────────────────────────────────────────────────────

# Comma-separated RSS feed URLs for news fetching
RSS_FEEDS=https://hnrss.org/frontpage,https://dev.to/feed

# Minimum AI quality score to post (0-10). Articles below this are skipped.
NEWS_MIN_SCORE=7


# ── OPTIONAL — STORAGE ────────────────────────────────────────────────────────

# SQLite database path (relative to project root)
DB_PATH=tbxpost.db
